<div class="max-w-4xl mx-auto p-8">
  <h1 class="text-3xl font-bold text-green-600 mb-6">✅ Turbo Test Page - Working!</h1>
  
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Test Form</h2>
    
    <div id="messages" class="space-y-2 mb-4">
      <div class="bg-gray-100 p-3 rounded">
        Try submitting the form below...
      </div>
    </div>
    
    <%= form_with url: turbo_test_index_path,
                  data: { turbo_stream: true },
                  class: "flex space-x-2" do |f| %>
      <%= f.text_field :message, 
            placeholder: "Type something...",
            class: "flex-1 border rounded px-3 py-2" %>
      <%= f.submit "Submit", 
            class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
    <% end %>
  </div>
  
  <div class="bg-green-50 border border-green-200 rounded-lg p-6">
    <h2 class="text-xl font-semibold text-green-800 mb-4">Route Helpers</h2>
    <ul class="space-y-2 text-sm">
      <li><code>turbo_test_index_path</code> → POST to create, GET to index</li>
      <li><code>turbo_test_path</code> → Would be for show/edit/destroy (not defined)</li>
      <li>Form submits to: <code><%= turbo_test_index_path %></code></li>
    </ul>
  </div>
</div>
